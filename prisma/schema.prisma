datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  
  notes         Note[]
  quizzes       Quiz[]
}

model Note {
  id              String   @id @default(uuid())
  userId          String
  arabic_text     String
  analysisJson    Json
  created_at      DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quiz {
  id             String   @id @default(uuid())
  userId         String
  question       String
  correct_answer String
  created_at     DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
